{
  "main": "vendor/autoload.php",
  "stub": false,
  "output": "vendor.phar",
  "check-requirements": false,
  "compression": "GZ",
  "finder": [
    {
      "name": "/.*\\.php|.*\\.json/",
      "exclude": [
        "doc",
        "test",
        "test_old",
        "tests",
        "Tests",
        "vendor-bin"
      ],
      "in": "vendor"
    }
  ]
}